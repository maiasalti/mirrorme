# ────────────────────────────────────────────────────────────────────
# Copy the relevant sections into web/.env.local and extension/.env.local
# ────────────────────────────────────────────────────────────────────

# ── web/.env.local ──────────────────────────────────────────────────
# Google AI Studio key (https://aistudio.google.com/apikey). SERVER ONLY —
# never referenced from client code; the extension never sees it.
GEMINI_API_KEY=

# Supabase project (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
# anon / publishable key (new-style sb_publishable_... keys also work)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role / secret key (sb_secret_... also works). SERVER ONLY — bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── extension/.env.local ────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=
# Where the Next.js app runs (http://localhost:3000 in dev, your Vercel URL in prod)
VITE_API_BASE_URL=http://localhost:3000
# Google Cloud OAuth client of type "Chrome Extension" (see README → Setup)
VITE_GOOGLE_OAUTH_CLIENT_ID=
# Base64 public key for a stable dev extension id (see README → Setup)
VITE_CRX_PUBLIC_KEY=
